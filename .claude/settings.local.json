{
  "permissions": {
    "allow": [
      "Bash(wc -l /d/Sportive.API/Controllers/*.cs)",
      "Bash(xargs wc:*)",
      "Bash(grep -A 5 \"ArgumentNullException\\\\|ArgumentException\" /d/Sportive.API/Services/*.cs)",
      "Read(//d/sportive-frontend/**)",
      "Bash(npx tsc:*)",
      "Bash(npx --prefix /d/sportive-frontend tsc -p /d/sportive-frontend/tsconfig.json --noEmit)",
