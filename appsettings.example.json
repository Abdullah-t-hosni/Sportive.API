{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_DB_HOST;Port=3306;Database=YOUR_DB_NAME;User=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SslMode=None;AllowPublicKeyRetrieval=true;",
    "Redis": ""
  },
  "AllowedOrigins": "",
  "JWT": {
    "Secret": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARACTERS",
    "Issuer": "Sportive.API",
    "Audience": "Sportive.Client",
    "ExpiresHours": "72"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Paymob": {
    "ApiKey": "YOUR_PAYMOB_API_KEY",
    "IntegrationId": "YOUR_INTEGRATION_ID",
    "IframeId": "",
    "HmacSecret": "YOUR_HMAC_SECRET"
  },
  "Cloudinary": {
    "CloudName": "YOUR_CLOUD_NAME",
    "ApiKey": "YOUR_CLOUDINARY_API_KEY",
    "ApiSecret": "YOUR_CLOUDINARY_API_SECRET"
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Limits": {
      "MaxRequestBodySize": 10485760
    }
  },
  "Store": {
    "Name": "YOUR_STORE_NAME",
    "Phone": "+20XXXXXXXXXX",
    "Url": "https://your-store-domain.com",
    "Address": "YOUR_STORE_ADDRESS"
  },
  "Backup": {
    "Enabled": true,
    "DailyTime": "02:00",
    "KeepDays": 30,
    "LocalPath": "/tmp/sportive-backups",
    "Email": {
      "Enabled": true,
      "SmtpHost": "smtp.gmail.com",
      "SmtpPort": 587,
      "Ssl": true,
      "SmtpUser": "your-email@gmail.com",
      "SmtpPass": "YOUR_GMAIL_APP_PASSWORD",
      "From": "backup@your-domain.com",
      "To": "admin@your-domain.com",
      "AttachLimitMb": 25
    }
  },
  "Email": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "User": "your-email@gmail.com",
    "Pass": "YOUR_GMAIL_APP_PASSWORD",
    "From": "your-email@gmail.com"
  },
  "WhatsApp": {
    "PhoneNumberId": "YOUR_WHATSAPP_PHONE_NUMBER_ID",
    "AccessToken": "YOUR_META_GRAPH_API_TOKEN",
    "TemplateName": "auth_otp_template",
    "LanguageCode": "ar"
  }
}
