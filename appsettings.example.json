{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_DB_HOST;Port=3306;Database=YOUR_DB_NAME;User=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;SslMode=Required;AllowPublicKeyRetrieval=true;Allow User Variables=true;",
    "Redis": ""
  },
  "AllowedOrigins": "",
